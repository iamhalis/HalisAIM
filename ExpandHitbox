--// SETTINGS
local NEW_SIZE = Vector3.new(6, 6, 6) -- chỉnh kích thước hitbox
local DEBUG_COLOR = Color3.fromRGB(0, 170, 255)

local Players = game:GetService("Players")

local function expandHitbox(character, player)
	if not character then return end

	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- tránh chạy nhiều lần
	if root:FindFirstChild("HitboxEdited") then return end

	-- đánh dấu
	local tag = Instance.new("BoolValue")
	tag.Name = "HitboxEdited"
	tag.Parent = root

	-- 🔥 TĂNG HITBOX THẬT (server thấy)
	root.Size = NEW_SIZE
	root.Transparency = 0.5
	root.Color = DEBUG_COLOR
	root.Material = Enum.Material.Neon
	root.CanCollide = true
end

local function onCharacter(player, character)
	task.wait(0.5)
	expandHitbox(character, player)
end

local function onPlayer(player)
	player.CharacterAdded:Connect(function(char)
		onCharacter(player, char)
	end)

	if player.Character then
		onCharacter(player, player.Character)
	end
end

-- chạy cho player hiện tại
for _, plr in ipairs(Players:GetPlayers()) do
	onPlayer(plr)
end

-- player mới vào
Players.PlayerAdded:Connect(onPlayer)
