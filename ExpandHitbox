--// HITBOX UI CLEAN VERSION

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local DEBUG_COLOR = Color3.fromRGB(0,170,255)
local MATERIAL = Enum.Material.Neon

local currentSize = 6
local enabled = true

pcall(function()
	if CoreGui:FindFirstChild("HitboxUI") then
		CoreGui.HitboxUI:Destroy()
	end
end)

local function applyHitbox(player, character)
	if not enabled or player == LocalPlayer or not character then return end

	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	root.Size = Vector3.new(currentSize,currentSize,currentSize)
	root.Transparency = 0.5
	root.Color = DEBUG_COLOR
	root.Material = MATERIAL
	root.CanCollide = false
end

local function resetHitbox(player, character)
	if player == LocalPlayer or not character then return end

	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	root.Size = Vector3.new(2,2,1)
	root.Transparency = 1
	root.CanCollide = false
end

local function refreshAll()
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character then
			applyHitbox(player, player.Character)
		end
	end
end

local function resetAll()
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character then
			resetHitbox(player, player.Character)
		end
	end
end

local function setupPlayer(player)
	player.CharacterAdded:Connect(function(character)
		if enabled then
			applyHitbox(player, character)
		end
	end)

	if player.Character and enabled then
		applyHitbox(player, player.Character)
	end
end

for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

Players.PlayerAdded:Connect(setupPlayer)

-- UI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "HitboxUI"
ScreenGui.Parent = CoreGui

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0,260,0,170)
MainFrame.Position = UDim2.new(0.7,0,0.2,0)
MainFrame.BackgroundColor3 = Color3.fromRGB(20,20,20)
MainFrame.Parent = ScreenGui

local ToggleButton = Instance.new("ImageButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0,70,0,70)
ToggleButton.Position = UDim2.new(0,40,0,40)
ToggleButton.BackgroundTransparency = 1
ToggleButton.Image = "rbxassetid://97203952126178"

local StatusButton = Instance.new("TextButton")
StatusButton.Size = UDim2.new(0,180,0,50)
StatusButton.Position = UDim2.new(0.5,-90,0,20)
StatusButton.Text = "Hitbox: ON"
StatusButton.Parent = MainFrame

local PlusButton = Instance.new("TextButton")
PlusButton.Size = UDim2.new(0,50,0,40)
PlusButton.Position = UDim2.new(0,30,0,100)
PlusButton.Text = "+"
PlusButton.Parent = MainFrame

local MinusButton = Instance.new("TextButton")
MinusButton.Size = UDim2.new(0,50,0,40)
MinusButton.Position = UDim2.new(1,-80,0,100)
MinusButton.Text = "-"
MinusButton.Parent = MainFrame

local SizeLabel = Instance.new("TextLabel")
SizeLabel.Size = UDim2.new(0,80,0,40)
SizeLabel.Position = UDim2.new(0.5,-40,0,100)
SizeLabel.Text = tostring(currentSize)
SizeLabel.Parent = MainFrame

-- drag
local dragging = false
local dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		MainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

PlusButton.MouseButton1Click:Connect(function()
	if enabled then
		currentSize += 1
		SizeLabel.Text = tostring(currentSize)
		refreshAll()
	end
end)

MinusButton.MouseButton1Click:Connect(function()
	if enabled then
		currentSize = math.max(1,currentSize-1)
		SizeLabel.Text = tostring(currentSize)
		refreshAll()
	end
end)

StatusButton.MouseButton1Click:Connect(function()
	enabled = not enabled
	StatusButton.Text = enabled and "Hitbox: ON" or "Hitbox: OFF"

	if enabled then
		refreshAll()
	else
		resetAll()
	end
end)

ToggleButton.MouseButton1Click:Connect(function()
	MainFrame.Visible = not MainFrame.Visible
end)
