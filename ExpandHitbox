--// SETTINGS
local NEW_SIZE = Vector3.new(6, 6, 6)
local DEBUG_COLOR = Color3.fromRGB(0, 170, 255)

-- ❗ đổi thành tên player bạn KHÔNG muốn tăng hitbox
local EXCLUDE_PLAYER_NAME = "hdhoangmain"

local Players = game:GetService("Players")

--// tăng hitbox
local function expandHitbox(player, character)
	if not character then return end
	
	-- 🚫 bỏ qua bản thân
	if player.Name == EXCLUDE_PLAYER_NAME then
		return
	end

	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- tránh chạy nhiều lần
	if root:FindFirstChild("HitboxEdited") then return end

	-- đánh dấu
	local tag = Instance.new("BoolValue")
	tag.Name = "HitboxEdited"
	tag.Parent = root

	-- 🔥 tăng hitbox thật (server)
	root.Size = NEW_SIZE
	root.Transparency = 0.5
	root.Color = DEBUG_COLOR
	root.Material = Enum.Material.Neon
	root.CanCollide = true
end

--// khi character spawn
local function onCharacter(player, character)
	task.wait(0.5)
	expandHitbox(player, character)
end

--// khi player vào
local function onPlayer(player)
	player.CharacterAdded:Connect(function(char)
		onCharacter(player, char)
	end)

	-- nếu đã có character sẵn
	if player.Character then
		onCharacter(player, player.Character)
	end
end

--// player hiện tại
for _, plr in ipairs(Players:GetPlayers()) do
	onPlayer(plr)
end

--// player mới vào (🔥 FIX CHO NGƯỜI MỚI)
Players.PlayerAdded:Connect(onPlayer)
